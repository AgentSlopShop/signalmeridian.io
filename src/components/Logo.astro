---
interface Props {
  class?: string;
}
const { class: cls = 'h-7 w-auto' } = Astro.props;
---

<a href="/" class={`inline-flex items-center gap-2.5 group ${cls}`} aria-label="Signal Meridian home">
  <svg
    viewBox="0 0 36 36"
    fill="none"
    aria-hidden="true"
    class="h-7 w-7 text-signal transition-transform duration-500 group-hover:rotate-[8deg]"
  >
    <circle cx="18" cy="18" r="15.5" stroke="currentColor" stroke-opacity="0.35" stroke-width="1" />
    <path
      d="M2.5 18 H10 l3 -8 4 16 4 -10 3 6 H33.5"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="18" cy="18" r="2.2" fill="currentColor" />
  </svg>
  <span class="font-semibold tracking-tight text-slate-100 text-[15px]">
    Signal<span class="text-signal">·</span>Meridian
  </span>
</a>
