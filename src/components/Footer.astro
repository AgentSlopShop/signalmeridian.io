---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-line/60 py-10 mt-8">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
    <div>
      <Logo />
      <p class="mt-3 text-xs text-slate-500 max-w-sm leading-relaxed">
        Signal Meridian. Senior technical assistance for systems that need to scale.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-8 text-xs text-slate-500 font-mono">
      <a href="mailto:hello@signalmeridian.io" class="hover:text-signal transition-colors">
        hello@signalmeridian.io
      </a>
      <span>© {year} Signal Meridian</span>
    </div>
  </div>
</footer>
