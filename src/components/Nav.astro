---
import Logo from './Logo.astro';

const links = [
  { href: '#offer-1', label: 'Infra cost' },
  { href: '#offer-2', label: 'App + agents' },
  { href: '#offer-3', label: 'Web3 + devrel' },
  { href: '#process', label: 'Process' },
  { href: '#team', label: 'Team' },
];
---

<header
  class="fixed top-0 inset-x-0 z-40 backdrop-blur-md bg-ink/65 border-b border-line/60"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8 h-14 flex items-center justify-between">
    <Logo />
    <nav class="hidden md:flex items-center gap-8 text-sm text-slate-300">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="hover:text-white transition-colors relative after:absolute after:left-0 after:-bottom-1 after:h-px after:w-0 after:bg-signal hover:after:w-full after:transition-all after:duration-300"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
    <a
      href="#contact"
      class="inline-flex items-center gap-2 rounded-md border border-signal/40 bg-signal/10 px-3.5 py-1.5 text-sm font-medium text-signal hover:bg-signal/20 hover:border-signal transition-colors"
    >
      Get in touch
      <svg viewBox="0 0 16 16" fill="none" class="h-3.5 w-3.5" aria-hidden="true">
        <path d="M3 8h10m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>
</header>
